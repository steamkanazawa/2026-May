# Pterodactyl Panel URL (末尾の / は不要です)
PTERODACTYL_PANEL_URL=https://panel.hikamerscraft.com

# Panel の Account > API Credentials で作成した Client API Key (ptlc_...)
# 絶対に public フォルダ内へ置いたり、GitHubへ公開したりしないでください。
PTERODACTYL_API_KEY=ptlc_REPLACE_WITH_YOUR_CLIENT_API_KEY

# ステータスページをローカルで待ち受けるポート
PORT=3000
HOST=127.0.0.1

# Panel / Minecraft の確認間隔。60000 = 60秒
POLL_INTERVAL_MS=60000

# APIやMinecraft Pingのタイムアウト
REQUEST_TIMEOUT_MS=5000
